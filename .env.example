# ===== 数据库（必须，Postgres）=====
# 本地可用 Neon / Supabase 等托管 Postgres，或 brew install postgres 后填本地地址
# 例如：postgresql://user:pass@host:5432/redtoronto?schema=public
DATABASE_URL=

# ===== 身份认证（NextAuth v5）=====
# 生产环境务必设置为强随机值；可用 `openssl rand -base64 32` 生成
AUTH_SECRET=
NEXTAUTH_SECRET=

# ===== AI 生成（可选，留空则使用规则兜底）=====
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest
