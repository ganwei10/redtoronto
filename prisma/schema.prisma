// 红多营运营平台 · 生产数据模型（Postgres + Prisma）
// 升级说明：npm install prisma @prisma/client && npx prisma generate && npx prisma db push
// 向量检索可后续将 Creator.embedding 改为 pgvector 的 vector 类型，见 docs/ARCHITECTURE.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ 身份认证（NextAuth 兼容）============
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("merchant") // merchant | operator | creator
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
  merchant      Merchant?
  creator       Creator?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============ 业务实体 ============
model Creator {
  id           String   @id @default(cuid())
  userId       String?  @unique
  handle       String
  platformId   String?
  followers    Int
  engagementRate Float // 0-1
  niche        String[]
  city         String
  rateCAD      Float
  availability Boolean  @default(true)
  pastCases    String[]
  embedding    Float[]
  note         String?
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Merchant {
  id        String   @id @default(cuid())
  userId    String?  @unique
  name      String
  industry  String
  contact   String
  email     String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  requests  MerchantRequest[]
  campaigns Campaign[]
}

// 商户提交的营销需求（v1.0 商户门户）
model MerchantRequest {
  id            String   @id @default(cuid())
  merchantId    String
  industry      String
  goal          String
  budget        Float
  audience      String
  sellingPoints String
  kpi           String
  duration      String
  brief         Json? // AI 生成的结构化 Brief
  status        String   @default("pending") // pending | reviewed | rejected
  createdAt     DateTime @default(now())
  merchant      Merchant @relation(fields: [merchantId], references: [id])
  campaign      Campaign?
}

model Campaign {
  id         String    @id @default(cuid())
  name       String
  merchantId String?
  brief      Json
  creatorIds String[]
  status     String    @default("draft") // draft | brief_ready | active | completed | reviewed
  budgetCAD  Float
  review     Json?
  metrics    Metric[]
  request    MerchantRequest? @relation(fields: [requestId], references: [id])
  requestId  String?   @unique
  merchant   Merchant? @relation(fields: [merchantId], references: [id])
  createdAt  DateTime  @default(now())
}

model Content {
  id         String   @id @default(cuid())
  campaignId String
  creatorId  String
  body       String
  status     String   @default("draft")
  flags      String[]
  createdAt  DateTime @default(now())
}

model Metric {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime
  impressions Int
  engagements Int
  clicks      Int
  leads       Int
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

// 复盘知识库（v0.4 沉淀，v1.x 接 RAG）
model KnowledgeEntry {
  id           String   @id @default(cuid())
  campaignId   String
  campaignName String
  review       Json
  text         String   // 供 RAG 检索的纯文本
  createdAt    DateTime @default(now())
}
